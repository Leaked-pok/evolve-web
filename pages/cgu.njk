      <div id="panel-risques" class="cgu-panel cgu-panel--hidden">
        <p class="cgu-panel__updated">Jouez de façon responsable.</p>

        <details class="accordion accordion--blue">
          <summary class="accordion__header">
            <span class="accordion__icon accordion__icon--blue">
