<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if module %}{{ module.title }} — Evolve Poker Academy{% else %}{{ texts[page_key].meta_title }}{% endif %}</title>
  <meta name="description" content="{% if module %}{{ module.description | truncate(160) }}{% else %}{{ texts[page_key].meta_desc }}{% endif %}">
  <meta name="robots" content="index, follow">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap" rel="stylesheet">

  <link rel="icon" type="image/png" href="/assets/images/logo.png">
  <link rel="stylesheet" href="/assets/css/style.css">
</head>
<body>

  <header class="nav">
    <div class="container">
      <nav class="nav__inner">
        <a href="/index.html" class="nav__logo">
          <img src="/assets/images/logo.png" alt="Evolve Poker" class="nav__logo-img">
        </a>
        <ul class="nav__links">
          <li class="nav__item">
            <button class="nav__link">Apps <span class="nav__link-arrow">▾</span></button>
            <div class="nav__dropdown">
              <a href="#" class="nav__dropdown-store">
                <div class="nav__dropdown-store__icon">&#xF8FF;</div>
                <div class="nav__dropdown-store__text">
                  <span class="nav__dropdown-store__sub">Télécharger sur l'</span>
                  <span class="nav__dropdown-store__name">App Store</span>
                </div>
              </a>
              <div class="nav__dropdown-divider"></div>
              <a href="#" class="nav__dropdown-store">
                <div class="nav__dropdown-store__icon">▶</div>
                <div class="nav__dropdown-store__text">
                  <span class="nav__dropdown-store__sub">Disponible sur</span>
                  <span class="nav__dropdown-store__name">Google Play</span>
                </div>
              </a>
            </div>
          </li>
          <li class="nav__item">
            <a href="/index.html" class="nav__link{% if activeNav == 'home' %} nav__link--active{% endif %}">Home</a>
          </li>
          <li class="nav__item">
            <a href="/pages/academy/academy.html" class="nav__link{% if activeNav == 'academy' %} nav__link--active{% endif %}">Academy</a>
          </li>
          <li class="nav__item">
            <a href="/pages/features/features.html" class="nav__link{% if activeNav == 'features' %} nav__link--active{% endif %}">Fonctionnalités</a>
          </li>
          <li class="nav__item">
            <a href="/pages/next/lasuite.html" class="nav__link{% if activeNav == 'lasuite' %} nav__link--active{% endif %}">La suite</a>
          </li>
          <li class="nav__item">
            <button class="nav__link{% if activeNav == 'evolve' %} nav__link--active{% endif %}">Evolve ? <span class="nav__link-arrow">▾</span></button>
            <div class="nav__dropdown">
              <a href="/cgu/#evolve" class="nav__dropdown-link">Evolve ?</a>
              <a href="/cgu/#risques" class="nav__dropdown-link">Risques du Poker</a>
              <a href="/cgu/#aide" class="nav__dropdown-link">Aide aux inscriptions</a>
              <div class="nav__dropdown-divider"></div>
              <a href="/cgu/#terms" class="nav__dropdown-link">Conditions d'utilisation</a>
              <a href="/cgu/#privacy" class="nav__dropdown-link">Confidentialité</a>
              <a href="/cgu/#faq" class="nav__dropdown-link">FAQ</a>
            </div>
          </li>
          <li class="nav__item">
            <a href="/pages/contact/contact.html" class="nav__link{% if activeNav == 'contact' %} nav__link--active{% endif %}">Contact</a>
          </li>
        </ul>
        <div class="nav__actions">
          <div class="nav__item">
            <button class="nav__globe-btn" aria-label="Changer de langue"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg></button>
            <div class="nav__dropdown nav__dropdown--right">
              <button class="nav__dropdown-lang nav__dropdown-lang--active"><span class="nav__dropdown-lang__flag">🇫🇷</span> Français</button>
              <button class="nav__dropdown-lang"><span class="nav__dropdown-lang__flag">🇬🇧</span> English</button>
            </div>
          </div>
          <button class="nav__burger" id="nav-burger" aria-label="Ouvrir le menu">
            <span></span><span></span><span></span>
          </button>
        </div>
      </nav>
    </div>
  </header>

  <!-- Mobile overlay -->
  <div class="nav-overlay" id="nav-overlay"></div>

  <!-- Mobile drawer -->
  <div class="nav-drawer" id="nav-drawer" aria-label="Menu navigation">
    <div class="nav-drawer__header">
      <a href="/index.html">
        <img src="/assets/images/logo.png" alt="Evolve Poker" class="nav-drawer__logo">
      </a>
      <button class="nav-drawer__close" id="nav-drawer-close" aria-label="Fermer">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <ul class="nav-drawer__links">
      <li><a href="/index.html" class="nav-drawer__link">Home</a></li>
      <li><a href="/pages/academy/academy.html" class="nav-drawer__link">Academy</a></li>
      <li><a href="/pages/features/features.html" class="nav-drawer__link">Fonctionnalités</a></li>
      <li><a href="/pages/next/lasuite.html" class="nav-drawer__link">La suite</a></li>
      <li><a href="/cgu/" class="nav-drawer__link">Evolve ?</a></li>
      <li><a href="/pages/contact/contact.html" class="nav-drawer__link">Contact</a></li>
    </ul>
    <div class="nav-drawer__stores">
      <a href="#" class="btn-store">
        <span class="btn-store__icon">&#xF8FF;</span>
        <span class="btn-store__text">
          <span class="btn-store__sub">Télécharger sur l'</span>
          <span class="btn-store__name">App Store</span>
        </span>
      </a>
      <a href="#" class="btn-store">
        <span class="btn-store__icon">▶</span>
        <span class="btn-store__text">
          <span class="btn-store__sub">Disponible sur</span>
          <span class="btn-store__name">Google Play</span>
        </span>
      </a>
    </div>
  </div>

  {{ content | safe }}

  <footer class="footer">
    <div class="container">

      <div class="footer__bar">
        <a href="/index.html">
          <img src="/assets/images/logo.png" alt="Evolve Poker" class="footer__logo-img">
        </a>
        <div class="footer__center">
          <p class="footer__beta-text">Version bêta — projet solo, né d'une passion pour le poker et d'un outil qui n'existait pas. Chaque retour compte.</p>
          <ul class="footer__links">
            <li><a href="/pages/academy/academy.html" class="footer__link">Academy</a></li>
            <li><a href="/pages/features/features.html" class="footer__link">Fonctionnalités</a></li>
            <li><a href="/pages/next/lasuite.html" class="footer__link">La suite</a></li>
            <li><a href="/cgu/" class="footer__link">Evolve ?</a></li>
            <li><a href="/pages/contact/contact.html" class="footer__link">Contact</a></li>
          </ul>
        </div>
        <div class="footer__social">
          <a href="#" class="footer__social-link" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/></svg>
          </a>
          <a href="#" class="footer__social-link" aria-label="X (Twitter)">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="#" class="footer__social-link" aria-label="TikTok">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.34-6.34V8.69a8.17 8.17 0 0 0 4.78 1.52V6.77a4.85 4.85 0 0 1-1.02-.08z"/></svg>
          </a>
          <a href="#" class="footer__social-link" aria-label="YouTube">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
        </div>
      </div>

      <div class="footer__bottom">
        <p class="footer__copy">{{ texts.site.copyright }}</p>
        <div class="footer__legal">
          <a href="/cgu/#privacy" class="footer__legal-link">Politique de confidentialité</a>
          <a href="/cgu/#terms" class="footer__legal-link">Conditions d'utilisation</a>
        </div>
      </div>
    </div>
  </footer>

  <script src="/assets/js/main.js"></script>

</body>
</html>
